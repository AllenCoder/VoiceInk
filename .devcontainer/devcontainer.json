{
  "name": "VoiceInk Dev (Linux)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ripgrep jq",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "github.vscode-pull-request-github",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  }
}
